# Database
DATABASE_URL="postgresql://user:password@localhost:5432/balaji_db"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-minimum-32-characters-long"
NEXTAUTH_URL="http://localhost:3000"

# Admin Credentials (for seeding)
ADMIN_EMAIL="admin@balajientrepreneurs.com"
ADMIN_PASSWORD="admin123"

# Optional: Email Service (if implementing email notifications)
# RESEND_API_KEY="re_xxxxxxxxxxxx"
# Get from: https://resend.com/api-keys

# Optional: Image Upload Service (if implementing image uploads)
# CLOUDINARY_CLOUD_NAME="your-cloud-name"
# CLOUDINARY_API_KEY="your-api-key"
# CLOUDINARY_API_SECRET="your-api-secret"
# Get from: https://cloudinary.com/console

# Optional: Google Maps (for location features)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"
# Get from: https://console.cloud.google.com/apis/credentials
